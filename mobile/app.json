{
  "expo": {
    "name": "Ravyn",
    "slug": "ravyn-mobile",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "ravyn",
    "userInterfaceStyle": "light",
    "assetBundlePatterns": [
      "**/*"
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#EFE4CF"
      }
    },
    "web": {
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
    ]
  }
}
